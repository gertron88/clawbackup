from setuptools import setup, find_packages

setup(
    name="moltvault-agent",
    version="2.0.1",
    description="MoltVault Agent SDK - Easy backup/restore for AI agents (Hosted Version)",
    author="Altron",
    author_email="",
    url="https://github.com/gertron88/moltvault",
    py_modules=["moltvault"],
    install_requires=[
        "requests>=2.28.0",
        "cryptography>=41.0.0",
    ],
    python_requires=">=3.8",
    classifiers=[
        "Development Status :: 4 - Beta",
        "Intended Audience :: Developers",
        "License :: OSI Approved :: MIT License",
        "Programming Language :: Python :: 3",
        "Topic :: System :: Archiving :: Backup",
    ],
    keywords="backup agent ai automation cloud supabase vercel",
)
